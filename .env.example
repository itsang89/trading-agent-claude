# Alpaca paper trading credentials
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Set this to the date the experiment officially started (YYYY-MM-DD)
# Used by get_spy_benchmark.py and append_metrics.py to compute cumulative returns
EXPERIMENT_START_DATE=2026-04-28

# Anthropic API key — used by Claude CLI and tools/learning_harness.py
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail SMTP credentials — used by tools/send_email.py for routine email summaries
# Use a Gmail App Password (not your account password): https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
